# Copy this to .env and fill in your values
JWT_SECRET=change-me-generate-with-python3-c-import-secrets-print-secrets.token_hex-32

# XCockpit connection settings
# BASE_URL: e.g. https://xcockpit.cycraft.ai (or your region-specific URL)
XCOCKPIT_URL=https://xcockpit.cycraft.ai

# Customer Key: the key in /_api/<customer_key>/...
# Ask CyCraft support for your customer key
XCOCKPIT_CUSTOMER_KEY=your-customer-key-here

# API Key: generated from XCockpit → Security → Create API Token
XCOCKPIT_API_KEY=your-xcockpit-api-key-here
